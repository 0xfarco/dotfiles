#!/bin/bash

set -e

ACTION="$1"

SRC_DIR="$HOME/.local/src"
DWM_DESKTOP_FILE="../dwm.desktop"

DWM_REPO="https://github.com/0xfarco/dwm"
DMENU_REPO="https://github.com/0xfarco/dmenu"
ST_REPO="https://github.com/0xfarco/st"
SLSTATUS_REPO="https://github.com/0xfarco/slstatus"

CUSTOM_BASH_PROFILE="../append_profile"
CUSTOM_BASHRC="../append_bashrc"

safe_append() {
    local file="$1"
    local content_file="$2"
    local marker="# BEGIN custom additions"

    [[ ! -f "$file" ]] && touch "$file"

    echo ""

    if ! grep -qF "$marker" "$file"; then
        echo "+ Updating $file..."
        {
            echo "$marker"
            cat "$content_file"
            echo "# END custom additions"
        } >> "$file"
    else
        echo "+ Already modified: $file"
    fi
}

add_marker_block() {
    local file="$1"
    local marker="$2"
    local block="$3"

    [[ ! -f "$file" ]] && touch "$file"

    if ! grep -qF "$marker" "$file"; then
        echo "+ Adding $marker block to $file"
        {
            echo "$marker"
            printf "%b\n" "$block"
        } >> "$file"
    else
        echo "+ $marker block already present in $file"
    fi
}

setup_shell_configs() {
    safe_append "$HOME/.bash_profile" "$CUSTOM_BASH_PROFILE"
    safe_append "$HOME/.bashrc" "$CUSTOM_BASHRC"
}

install_packages() {
    sudo emerge --ask=n \
        x11-base/xorg-server \
        x11-apps/xinit \
        x11-libs/libX11 \
        x11-libs/libXft \
        x11-libs/libXinerama \
        media-gfx/feh \
        x11-misc/picom \
        x11-misc/sxhkd \
        media-fonts/dejavu \
        media-fonts/noto \
        media-fonts/iosevka
}

build_suckless() {

	if [[ ! -d "$SRC_DIR" ]]; then
        echo "Creating $SRC_DIR..."
        sudo mkdir -p "$SRC_DIR"
    fi

    declare -A REPOS=(
        [dwm]="$DWM_REPO"
        [dmenu]="$DMENU_REPO"
        [st]="$ST_REPO"
        [slstatus]="$SLSTATUS_REPO"
    )

    for name in "${!REPOS[@]}"; do

        if command -v "$name"; then
            echo "$name is already installed, skipping."
            continue
        fi

        repo="${REPOS[$name]}"
        dest="$SRC_DIR/$name"

        rm -rf "$dest"

        git clone "$repo" "$dest"

        (
            cd "$dest"
            make
            sudo make clean install
        )
    done

	sudo install -Dm644 "$DWM_DESKTOP_FILE" /usr/share/xsessions/dwm.desktop
}

setup_xinitrc() {

cat > "$HOME/.xinitrc" <<EOF
slstatus &
picom &
feh --bg-scale ~/Pictures/wallpaper/gentoo.png &
sxhkd -c ~/.config/sxhkd/sxhkdrc &
exec dwm
EOF

}

remove_suckless() {

    for name in dwm dmenu slstatus; do

        if ! command -v "$name"; then
            echo "$name is not installed, skipping."
            continue
        fi

        dir="$SRC_DIR/$name"

        if [[ -d "$dir" ]]; then
            (
                cd "$dir"

                sudo make uninstall 2>/dev/null || true
                sudo make clean 2>/dev/null || true
            )
        fi

        sudo rm -f "/usr/local/bin/$name"
    done

    rm -rf \
        "$SRC_DIR/dwm" \
        "$SRC_DIR/dmenu" \
        "$SRC_DIR/slstatus"

	rm $HOME/.xinitrc
	sudo rm /usr/share/xsessions/dwm.desktop
}

case "$ACTION" in

    install)
        install_packages
        build_suckless
        setup_xinitrc
        setup_shell_configs
        echo "DWM installed."
        ;;

    remove)
        remove_suckless
        echo "DWM removed."
        ;;

    *)
        echo "Usage: $0 {install|remove}"
        exit 1
        ;;

esac
